# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Required ---

# Coinos Lightning API token
# Get it at: coinos.io → Settings → API → Generate Token
COINOS_API_KEY=your_coinos_token_here

# Secret for signing L402 macaroons (≥32 chars of entropy)
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
L402_SECRET=replace_with_64_hex_chars_of_entropy

# --- Optional ---

# 1inch Aggregation API key (free tier at portal.1inch.dev)
# Without this, 1inch requests are rate-limited to ~1 req/s
ONEINCH_API_KEY=your_1inch_key_here

# Price per /v1/quote call in satoshis (default: 10)
OPTIMIZER_PRICE_SATS=10

# How long (seconds) a minted macaroon is valid for payment (default: 600)
MACAROON_TTL_SECONDS=600

# Python logging level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
